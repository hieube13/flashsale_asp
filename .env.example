# Root config
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5080

# MySQL (mirror Java application.yml: localhost:3316, vetautet, root/root1234)
ConnectionStrings__MySql=server=localhost;port=3316;database=vetautet;user=root;password=root1234;Pooling=true;MaximumPoolSize=100;MinimumPoolSize=20;

# Redis (mirror Java: localhost:6319)
Redis__ConnectionString=localhost:6319,abortConnect=false,connectTimeout=30000

# Kafka (mirror Java: localhost:9094 KRaft)
Kafka__BootstrapServers=localhost:9094
Kafka__OrderPlaceTopic=order-place-topic
Kafka__ConsumerGroupId=order-consumer-group

# VNPay sandbox (Java uses hardcoded literal "SECRET" — replaced with env var in .NET fix path)
VnPay__SecretKey=REPLACE_WITH_VNPAY_SANDBOX_SECRET
VnPay__TmnCode=VNPAYSANDBOX
VnPay__Url=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VnPay__ReturnUrl=http://127.0.0.1:8080/payment/callback

# Serilog
Serilog__MinimumLevel__Default=Information
Serilog__MinimumLevel__Override__Microsoft=Warning
Serilog__MinimumLevel__Override__Microsoft__AspNetCore=Information